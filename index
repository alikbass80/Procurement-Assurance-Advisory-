<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Procurement Assurance Advisory</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0f2240;
    --navy-mid: #1a3356;
    --navy-light: #1e3d6b;
    --charcoal: #2c2c2c;
    --charcoal-mid: #3d3d3d;
    --white: #ffffff;
    --off-white: #f8f7f5;
    --soft-grey: #e8e6e1;
    --mid-grey: #9a9690;
    --light-grey: #f2f1ef;
    --accent: #b08d57;
    --accent-light: #c9a96e;
    --text-body: #3a3835;
    --text-light: #6b6763;

    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Jost', 'Helvetica Neue', sans-serif;
  }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    font-family: var(--font-body);
    font-weight: 300;
    color: var(--text-body);
    background: var(--white);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 3rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(15, 34, 64, 0.97);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(176, 141, 87, 0.2);
    transition: box-shadow 0.3s ease;
  }

  nav.scrolled {
    box-shadow: 0 2px 24px rgba(0,0,0,0.18);
  }

  .nav-brand {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .nav-brand-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: var(--white);
    line-height: 1.2;
  }

  .nav-brand-tagline {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 400;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 400;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.25s;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
  }

  .nav-links a:hover {
    color: var(--accent-light);
    border-bottom-color: var(--accent-light);
  }

  .nav-cta {
    font-size: 0.65rem !important;
    letter-spacing: 0.18em;
    background: var(--accent) !important;
    color: var(--white) !important;
    padding: 0.5rem 1.2rem !important;
    border: none !important;
    transition: background 0.25s !important;
  }

  .nav-cta:hover {
    background: var(--accent-light) !important;
    border-bottom-color: transparent !important;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    background: none;
    border: none;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--white);
    transition: all 0.3s;
  }

  #hero {
    min-height: 100vh;
    background: var(--navy);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 50%, rgba(30, 61, 107, 0.6) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(176, 141, 87, 0.08) 0%, transparent 60%);
  }

  .hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.5;
  }

  .hero-accent-line {
    position: absolute;
    right: 0;
    top: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(176,141,87,0.4) 40%, rgba(176,141,87,0.2) 70%, transparent);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 8rem 3rem 5rem;
    width: 100%;
  }

  .hero-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 400;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 36px;
    height: 1px;
    background: var(--accent);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 1.1;
    color: var(--white);
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    max-width: 700px;
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }

  .hero-subheadline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    color: rgba(255,255,255,0.65);
    font-weight: 300;
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }

  .hero-divider {
    width: 48px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.7s forwards;
  }

  .hero-body {
    font-size: 0.95rem;
    line-height: 1.85;
    color: rgba(255,255,255,0.55);
    max-width: 560px;
    margin-bottom: 3rem;
    font-weight: 300;
    opacity: 0;
    animation: fadeUp 0.8s 0.8s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s 1s forwards;
  }

  .btn-primary {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    background: var(--accent);
    color: var(--white);
    padding: 1rem 2.2rem;
    text-decoration: none;
    transition: background 0.25s, transform 0.2s;
  }

  .btn-primary:hover {
    background: var(--accent-light);
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 400;
    background: transparent;
    color: rgba(255,255,255,0.8);
    padding: 1rem 2.2rem;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.25);
    transition: border-color 0.25s, color 0.25s, transform 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent-light);
    transform: translateY(-1px);
  }

  section {
    padding: 6rem 3rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .section-label {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: var(--accent);
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--navy);
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin-bottom: 2rem;
  }

  #about {
    background: var(--off-white);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 6rem;
    align-items: start;
  }

  .about-left {
    position: sticky;
    top: 120px;
  }

  .about-text p {
    font-size: 1rem;
    line-height: 1.9;
    color: var(--text-body);
    margin-bottom: 1.4rem;
    font-weight: 300;
  }

  .about-text p:last-child { margin-bottom: 0; }

  #services {
    background: var(--white);
  }

  .services-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  .services-intro {
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--text-light);
    font-weight: 300;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--soft-grey);
    border: 1px solid var(--soft-grey);
  }

  .service-card {
    background: var(--white);
    padding: 2.5rem;
    position: relative;
    transition: background 0.3s;
  }

  .service-card:hover {
    background: var(--navy);
  }

  .service-card:hover .service-num,
  .service-card:hover .service-title,
  .service-card:hover .service-body {
    color: rgba(255,255,255,0.9);
  }

  .service-card:hover .service-num {
    color: var(--accent);
  }

  .service-card:hover .service-divider {
    background: var(--accent);
  }

  .service-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--accent);
    font-weight: 300;
    margin-bottom: 1.5rem;
    transition: color 0.3s;
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--navy);
    line-height: 1.25;
    margin-bottom: 1rem;
    transition: color 0.3s;
  }

  .service-divider {
    width: 28px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 1.25rem;
    transition: background 0.3s;
  }

  .service-body {
    font-size: 0.88rem;
    line-height: 1.85;
    color: var(--text-light);
    font-weight: 300;
    transition: color 0.3s;
  }

  #why {
    background: var(--navy);
    padding: 6rem 3rem;
  }

  #why .section-title {
    color: var(--white);
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    margin-top: 3.5rem;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .why-item {
    padding: 2.5rem 3rem;
    border-right: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    position: relative;
    transition: background 0.3s;
  }

  .why-item:hover {
    background: rgba(255,255,255,0.04);
  }

  .why-item:nth-child(even) { border-right: none; }
  .why-item:nth-child(3),
  .why-item:nth-child(4) { border-bottom: none; }

  .why-icon {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .why-text {
    font-size: 1rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.7;
    font-weight: 300;
  }

  #experience {
    background: var(--light-grey);
  }

  .experience-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 6rem;
    align-items: start;
  }

  .exp-left {
    position: sticky;
    top: 120px;
  }

  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--soft-grey);
  }

  .exp-list li {
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--soft-grey);
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .exp-bullet {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 0.5rem;
  }

  .exp-text {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text-body);
    font-weight: 300;
  }

  #quote {
    background: var(--charcoal);
    padding: 7rem 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  #quote::before {
    content: '\201C';
    position: absolute;
    font-family: var(--font-display);
    font-size: 30rem;
    color: rgba(255,255,255,0.025);
    top: -8rem;
    left: 50%;
    transform: translateX(-50%);
    line-height: 1;
    pointer-events: none;
  }

  .quote-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 300;
    color: rgba(255,255,255,0.88);
    line-height: 1.5;
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .quote-accent {
    width: 36px;
    height: 1px;
    background: var(--accent);
    margin: 2rem auto 0;
  }

  #when-engaged {
    background: var(--off-white);
  }

  .when-engaged-grid {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 6rem;
    align-items: start;
  }

  .when-engaged-left {
    position: sticky;
    top: 120px;
  }

  .when-engaged-list {
    list-style: none;
    border-top: 1px solid var(--soft-grey);
  }

  .when-engaged-list li {
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--soft-grey);
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 1.25rem;
    align-items: center;
  }

  .when-engaged-list .exp-bullet {
    margin-top: 0;
  }

  .when-engaged-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-body);
    font-weight: 300;
  }

  #contact {
    background: var(--white);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 6rem;
    align-items: start;
  }

  .contact-info-block {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-bottom: 1px solid var(--soft-grey);
    padding-bottom: 1.5rem;
  }

  .contact-info-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .contact-label {
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 400;
  }

  .contact-value {
    font-size: 0.92rem;
    color: var(--text-body);
    text-decoration: none;
    font-weight: 300;
    transition: color 0.2s;
  }

  .contact-value:hover { color: var(--navy); }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--text-light);
  }

  .form-group input,
  .form-group textarea {
    background: var(--off-white);
    border: 1px solid var(--soft-grey);
    border-bottom: 2px solid var(--soft-grey);
    padding: 0.85rem 1rem;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--text-body);
    outline: none;
    transition: border-color 0.25s, background 0.25s;
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--navy);
    border-bottom-color: var(--accent);
    background: var(--white);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.7;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: var(--font-body);
    background: var(--navy);
    color: var(--white);
    padding: 1rem 2.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.25s, transform 0.2s;
    align-self: flex-start;
  }

  .btn-submit:hover {
    background: var(--navy-light);
    transform: translateY(-1px);
  }

  .btn-submit svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    transition: transform 0.2s;
  }

  .btn-submit:hover svg { transform: translateX(3px); }

  footer {
    background: var(--navy);
    padding: 3rem;
    border-top: 1px solid rgba(176,141,87,0.2);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer-brand-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.03em;
  }

  .footer-tagline {
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 400;
  }

  .footer-copy {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: none;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--navy);
    z-index: 99;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
  }

  .mobile-menu.open { display: flex; }

  .mobile-menu a {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-weight: 300;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .mobile-menu a:hover { color: var(--accent-light); }

  .mobile-close {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255,255,255,0.6);
    font-size: 1.5rem;
    font-family: var(--font-display);
    line-height: 1;
  }

  @media (max-width: 900px) {
    nav { padding: 0 1.5rem; }

    .nav-links { display: none; }
    .hamburger { display: flex; }

    section { padding: 4.5rem 1.5rem; }

    .hero-content { padding: 7rem 1.5rem 4rem; }

    .about-grid,
    .experience-grid,
    .contact-grid,
    .services-header,
    .when-engaged-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-left,
    .exp-left,
    .when-engaged-left {
      position: static;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .why-item:nth-child(even) { border-right: none; }
    .why-item:nth-child(3) { border-bottom: 1px solid rgba(255,255,255,0.08); }
    .why-item:nth-child(4) { border-bottom: none; }
    .why-item { border-right: none !important; }

    .form-row { grid-template-columns: 1fr; }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    #quote { padding: 5rem 1.5rem; }
    #why { padding: 4.5rem 1.5rem; }
    footer { padding: 2.5rem 1.5rem; }
  }

  @media (max-width: 480px) {
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .btn-primary, .btn-secondary { width: 100%; text-align: center; }
    .btn-submit { width: 100%; justify-content: center; }
  }
</style>
</head>
<body>

